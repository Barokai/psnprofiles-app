{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "schedule:weekly"
  ],
  "prConcurrentLimit": 5,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all Ktor modules — monorepo, must stay in sync",
      "groupName": "Ktor",
      "matchPackageNames": [
        "io.ktor:{/,}**"
      ]
    },
    {
      "description": "Group Kotlin stdlib, compiler and KotlinX libraries",
      "groupName": "Kotlin & KotlinX",
      "matchPackageNames": [
        "org.jetbrains.kotlin{/,}**",
        "org.jetbrains.kotlinx{/,}**"
      ]
    },
    {
      "description": "Group Compose Multiplatform runtime and components",
      "groupName": "Compose Multiplatform",
      "matchPackageNames": [
        "org.jetbrains.compose{/,}**"
      ]
    },
    {
      "description": "Group AndroidX libraries",
      "groupName": "AndroidX",
      "matchPackageNames": [
        "androidx.{/,}**"
      ]
    },
    {
      "description": "Group Voyager navigation modules",
      "groupName": "Voyager",
      "matchPackageNames": [
        "cafe.adriel.voyager:{/,}**"
      ]
    },
    {
      "description": "Group multiplatform-settings modules",
      "groupName": "Multiplatform Settings",
      "matchPackageNames": [
        "com.russhwolf:multiplatform-settings{/,}**"
      ]
    },
    {
      "description": "Group all GitHub Actions version updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["dependencies", "github-actions"]
    },
    {
      "description": "Pin ksoup to 0.1.x — 0.2.x requires Kotlin 2.3+ which is incompatible with the current Kotlin 1.9.21 baseline",
      "matchPackageNames": [
        "com.fleeksoft.ksoup:ksoup"
      ],
      "allowedVersions": "<0.2.0"
    }
  ]
}

